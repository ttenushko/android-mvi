<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_main"
    app:startDestination="@id/placesFragment">

    <fragment
        android:id="@+id/placesFragment"
        android:name="com.ttenushko.androidmvi.demo.presentation.screens.places.PlacesFragment"
        android:label="PlacesFragment" >
        <action
            android:id="@+id/action_placesFragment_to_addPlaceFragment"
            app:destination="@id/addPlaceFragment" />
        <action
            android:id="@+id/action_placesFragment_to_placeDetailsFragment"
            app:destination="@id/placeDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/addPlaceFragment"
        android:name="com.ttenushko.androidmvi.demo.presentation.screens.addplace.AddPlaceFragment"
        android:label="AddPlaceFragment" />
    <fragment
        android:id="@+id/placeDetailsFragment"
        android:name="com.ttenushko.androidmvi.demo.presentation.screens.placedetails.PlaceDetailsFragment"
        android:label="PlaceDetailsFragment" />
</navigation>